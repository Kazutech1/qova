# Server
PORT=3000

# MongoDB (via Prisma)
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/qova?retryWrites=true&w=majority"

# Auth
JWT_SECRET=

# Nomba
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_ACCOUNT_ID=
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
# Signature key from the Nomba dashboard when configuring the webhook.
# Required — webhooks are rejected (401) if this is unset.
NOMBA_WEBHOOK_SIGNATURE_KEY=

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Termii (SMS + OTP)
TERMII_API_KEY=
TERMII_SENDER_ID=

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Sentry
SENTRY_DSN=
